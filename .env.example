# Copy to .env and fill in. NEVER commit the real .env.
#
# InstaScribe selects a model backend at runtime. Pick one:
#
#   INSTASCRIBE_BACKEND=openai     (default) hosted OpenAI — needs OPENAI_API_KEY
#   INSTASCRIBE_BACKEND=anthropic  Claude (vision + text) — needs ANTHROPIC_API_KEY
#   INSTASCRIBE_BACKEND=gemini     Google Gemini (vision + text) — needs GEMINI_API_KEY
#   INSTASCRIBE_BACKEND=local      fully local, no key — Ollama (vision + text) + Kokoro (TTS)
#   INSTASCRIBE_BACKEND=fake       deterministic placeholders — no key, no model (tests/smoke)
#
# Override one capability at a time (each: openai | anthropic | gemini | local | fake):
#   VISION_PROVIDER=  TEXT_PROVIDER=  TTS_PROVIDER=
# anthropic and gemini cover vision + text only; their TTS uses OpenAI unless you
# set TTS_PROVIDER=local (Kokoro, keyless).
INSTASCRIBE_BACKEND=openai

# --- OpenAI backend ---
# Needs gpt-4.1 (vision), gpt-4o-mini (Smart Fill), tts-1-hd (narration).
OPENAI_API_KEY=sk-your-key-here
# Point the OpenAI client at any compatible server (Ollama / vLLM / LM Studio / OpenRouter):
# OPENAI_BASE_URL=http://localhost:11434/v1

# --- Anthropic (Claude) backend ---  (pip install -r requirements-providers.txt)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-opus-4-8      # claude-haiku-4-5 is a cheaper Smart Fill choice

# --- Google Gemini backend ---  (no extra install — reuses the openai client)
# GEMINI_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-2.5-flash

# --- Local backend (INSTASCRIBE_BACKEND=local) ---
# Install Ollama (https://ollama.com): ollama pull qwen2.5vl:7b && ollama pull qwen2.5:7b
# pip install -r requirements-local.txt   (Kokoro TTS)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# VISION_MODEL=qwen2.5vl:7b
# TEXT_MODEL=qwen2.5:7b

# --- Optional overrides (sensible defaults exist in code) ---
# JOB_MODEL=gpt-4.1          # vision model on the OpenAI backend
# JOB_IMAGE_DETAIL=low       # low | high
# TTS_MODEL=tts-1-hd         # OpenAI TTS model

# --- Study / deploy-only settings (single-origin Flask server) ---
# MAX_CONCURRENT_RENDERS=2               # cap on simultaneous ffmpeg renders
# STUDY_QUESTIONNAIRE_URL=               # post-study questionnaire link (no rebuild needed)
# STUDY_QUESTIONNAIRE_PARAM=session
