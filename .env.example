# Copy to .env and fill in. NEVER commit the real .env.
# Required: an OpenAI API key with access to gpt-4.1, gpt-4o-mini, and tts-1-hd.
OPENAI_API_KEY=sk-your-key-here

# --- Optional runtime overrides (sensible defaults exist in code) ---
# Model used for per-scene scene drafting (vision + language).
# JOB_MODEL=gpt-4.1
# Image detail sent to the vision model: low | high.
# JOB_IMAGE_DETAIL=low

# Study/deploy-only settings (single-origin Flask server).
# Cap on simultaneous ffmpeg renders.
# MAX_CONCURRENT_RENDERS=2
# Post-study questionnaire link, changeable without a rebuild.
# STUDY_QUESTIONNAIRE_URL=
# STUDY_QUESTIONNAIRE_PARAM=session
