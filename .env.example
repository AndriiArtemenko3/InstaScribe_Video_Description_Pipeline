# Copy to .env and fill in. NEVER commit the real .env.
#
# InstaScribe selects a model backend at runtime. Pick one:
#
#   INSTASCRIBE_BACKEND=openai   (default) hosted OpenAI — best quality, needs a key
#   INSTASCRIBE_BACKEND=local    fully local, no key — Ollama (vision + text) + Kokoro (TTS)
#   INSTASCRIBE_BACKEND=fake     deterministic placeholders — no key, no model (tests/smoke)
#
# Or set one capability at a time (each: openai | local | fake), which overrides
# INSTASCRIBE_BACKEND for that stage:
#   VISION_PROVIDER=  TEXT_PROVIDER=  TTS_PROVIDER=
INSTASCRIBE_BACKEND=openai

# --- OpenAI backend (needed only when a capability uses `openai`) ---
# Needs access to gpt-4.1 (vision), gpt-4o-mini (Smart Fill), tts-1-hd (narration).
OPENAI_API_KEY=sk-your-key-here
# Point the OpenAI client at any compatible server (Ollama / vLLM / LM Studio / OpenRouter).
# Covers vision + text; hosted TTS has no local-compatible endpoint (use the local TTS).
# OPENAI_BASE_URL=http://localhost:11434/v1

# --- Local backend (INSTASCRIBE_BACKEND=local) ---
# 1) Install Ollama (https://ollama.com), then:
#      ollama pull qwen2.5vl:7b && ollama pull qwen2.5:7b
# 2) pip install -r requirements-local.txt   (Kokoro TTS)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# VISION_MODEL=qwen2.5vl:7b
# TEXT_MODEL=qwen2.5:7b

# --- Optional runtime overrides (sensible defaults exist in code) ---
# JOB_MODEL=gpt-4.1          # vision model on the OpenAI backend
# JOB_IMAGE_DETAIL=low       # low | high
# TTS_MODEL=tts-1-hd         # OpenAI TTS model

# --- Study / deploy-only settings (single-origin Flask server) ---
# MAX_CONCURRENT_RENDERS=2               # cap on simultaneous ffmpeg renders
# STUDY_QUESTIONNAIRE_URL=               # post-study questionnaire link (no rebuild needed)
# STUDY_QUESTIONNAIRE_PARAM=session
